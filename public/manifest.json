{
  "manifest_version": 3,
  "name": "KueskiPay Widget",
  "version": "1.0.0",
  "description": "Tu crédito KueskiPay siempre disponible mientras navegas",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://nhpkrbgvdtjwvgrvjqyf.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "content_script.js"
      ]
    },
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "fab.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": [
      "icon16.png",
      "icon48.png",
      "icon128.png",
      "kueski.png",
      "kueskipay.png",
      "kueskilogo.png",
      "kueskiPayconmacetita.png",
      "jakarta.woff2"
    ],
    "matches": ["<all_urls>"]
  }]
}